# Google OAuth Web client ID (public — safe to ship in the frontend bundle).
# Must be the SAME client ID your backend verifies the idToken against,
# and a "Web application" OAuth client with http://localhost:5173 listed
# under "Authorized JavaScript origins" in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Base URL of the auth backend. Leave blank to use the Vite dev proxy
# (requests to /auth/* are forwarded to VITE_AUTH_PROXY_TARGET below).
VITE_AUTH_API_BASE=

# Where the dev server proxies /auth/* and /competitions requests (your backend).
VITE_AUTH_PROXY_TARGET=http://localhost:3000

# Base URL of the API backend (competitions etc). Leave blank to use the Vite
# dev proxy (requests to /competitions are forwarded to VITE_AUTH_PROXY_TARGET).
VITE_API_BASE=

# Comma-separated list of admin emails. A signed-in user whose email is listed
# here sees the "Admin" button and can open the organizer dashboard (#admin).
# (A backend can also flag a session as admin via role/isAdmin.)
VITE_ADMIN_EMAILS=
